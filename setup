#!/usr/bin/env bash
# setup — Bazaar's idempotent, re-runnable installer (gstack-style ergonomics).
#
# The one-paste install:
#   git clone https://github.com/jerryneoneo/bazaar-skills.git ~/bazaar-skills && cd ~/bazaar-skills && ./setup
#
# Run it again any time (e.g. after `git pull`) — it's idempotent: it refreshes the global
# launchers + config and runs any pending migrations, and only walks you through the conversational
# onboarding on the FIRST run (when no data/seller_config.json exists yet).
#
# What it does, in order:
#   1. prereqs + macOS TCC gate            5. global launchers (so /sell, /bazaar work anywhere)
#   2. pick the harness (Claude Code)      6. migrations + version stamp
#   3. sign-in gate                        7. first run -> guided onboarding; re-run -> refresh + exit
#   4. record home/host in ~/.bazaar
#
# Flags (all optional; smart defaults so it never blocks in CI):
#   --host <claude|claude-code|codex>   pick the harness (default: menu on a TTY, else claude-code)
#   --autonomy <hands-free|balanced|all-steps>   record the autonomy preset (default: balanced)
#   --no-install                        don't auto-install missing deps (Node/Chrome) via Homebrew
#   --prefix | --no-prefix              prefix global launcher names with 'bazaar-' (default: no)
#   --team | --no-team                  reserved for shared-repo auto-update (default: off)
#   --yes                               non-interactive; take defaults, never prompt
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SELF_DIR"
HANDOFF_PROMPT="follow .claude/commands/bazaar-install.md to set me up"

say()  { printf '\033[1;36mBazaar:\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33mBazaar:\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31mBazaar:\033[0m %s\n' "$*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }
# Are we running inside an agent (Claude Code / Codex) rather than a person at a terminal? Such a
# context has /dev/tty but no human to answer it: reads block, and an exec'd nested agent is invisible.
in_agent()       { [ -n "${CLAUDECODE:-}" ] || [ -n "${AI_AGENT:-}" ] || [ -n "${BAZAAR_DAEMON_PASS:-}" ]; }
can_attach_tty() { [ -t 0 ] && [ -t 1 ] && [ -e /dev/tty ] && ! in_agent; }   # a REAL interactive terminal

# --- dependency auto-install helpers (macOS / Homebrew) --------------------------------------
brew_bin() {
  command -v brew 2>/dev/null && return 0
  [ -x /opt/homebrew/bin/brew ] && { echo /opt/homebrew/bin/brew; return 0; }
  [ -x /usr/local/bin/brew ]   && { echo /usr/local/bin/brew;   return 0; }
  return 1
}
confirm_yes() {  # confirm_yes "question" -> 0 yes / 1 no; auto-yes with --yes; no real terminal -> no
  [ "$ASSUME_YES" = 1 ] && return 0
  can_attach_tty || return 1
  printf '\033[1;36mBazaar:\033[0m %s [Y/n] ' "$1" >/dev/tty
  local ans=""; read -r ans </dev/tty || return 1
  case "$ans" in n|N|no|NO) return 1 ;; *) return 0 ;; esac
}
ensure_brew() {  # make `brew` usable this session (macOS); install it if absent. return 0 if available
  local b
  if b="$(brew_bin)"; then eval "$("$b" shellenv)" 2>/dev/null || true; return 0; fi
  [ "$OS" = macos ] || return 1
  say "Installing Homebrew (needed to install the dependencies)…"
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" </dev/tty \
    || { warn "Homebrew install failed — install Node/Chrome by hand."; return 1; }
  if b="$(brew_bin)"; then eval "$("$b" shellenv)" 2>/dev/null || true; fi
  command -v brew >/dev/null 2>&1
}

# --- flags -----------------------------------------------------------------------------------
HOST="" ; AUTONOMY="balanced" ; PREFIX=0 ; TEAM="" ; ASSUME_YES=0 ; INSTALL_DEPS=1
while [ $# -gt 0 ]; do
  case "$1" in
    --host)       HOST="${2:-}"; shift 2 ;;
    --autonomy)   AUTONOMY="${2:-balanced}"; shift 2 ;;
    --prefix)     PREFIX=1; shift ;;
    --no-prefix)  PREFIX=0; shift ;;
    --team)       TEAM=1; shift ;;
    --no-team)    TEAM=0; shift ;;
    --yes|-y)     ASSUME_YES=1; shift ;;
    --no-install) INSTALL_DEPS=0; shift ;;
    -h|--help)    sed -n '2,30p' "$0"; exit 0 ;;
    *)            die "unknown flag: $1 (try --help)" ;;
  esac
done
[ -n "${BAZAAR_AGENT:-}" ] && [ -z "$HOST" ] && HOST="$BAZAAR_AGENT"  # back-compat env override

# --- 1. OS + prereqs -------------------------------------------------------------------------
case "$(uname -s)" in
  Darwin) OS=macos ;;
  Linux)  OS=linux ; warn "Linux is unverified — the launchd daemon is macOS-only; interactive mode should work." ;;
  *)      die "Unsupported OS. On Windows run the PowerShell installer (install.ps1)." ;;
esac
have git     || die "git is required. Install it and re-run."
have python3 || die "python3 is required. Install it and re-run."
# Node + Chrome power the browser tool. On macOS, offer to auto-install whichever is missing via
# Homebrew (one consent prompt; --yes auto-accepts, --no-install skips, no TTY skips). Other OSes warn.
need_node=0;   have npx || need_node=1
need_chrome=0; [ "$OS" = macos ] && [ ! -d "/Applications/Google Chrome.app" ] && need_chrome=1
if [ "$OS" = macos ] && [ "$INSTALL_DEPS" = 1 ] && { [ "$need_node" = 1 ] || [ "$need_chrome" = 1 ]; }; then
  miss=""; [ "$need_node" = 1 ] && miss="Node"
  [ "$need_chrome" = 1 ] && miss="${miss:+$miss + }Google Chrome"
  if confirm_yes "Install missing dependencies ($miss) with Homebrew?" && ensure_brew; then
    [ "$need_node" = 1 ]   && { say "Installing Node…";           brew install node                 && need_node=0   || warn "brew install node failed."; }
    [ "$need_chrome" = 1 ] && { say "Installing Google Chrome…";  brew install --cask google-chrome && need_chrome=0 || warn "brew install google-chrome failed."; }
  fi
fi
have npx || warn "Node/npx not found — needed for the Playwright browser tool. Install with: brew install node (or via nvm)."
if [ "$OS" = macos ] && [ ! -d "/Applications/Google Chrome.app" ]; then
  warn "Google Chrome not found — the agent drives a real Chrome. Install with: brew install --cask google-chrome."
fi

# --- macOS TCC gate: the runtime dir must be readable by launchd ------------------------------
if [ "$OS" = macos ]; then
  case "$SELF_DIR" in
    "$HOME/Documents"/*|"$HOME/Desktop"/*|"$HOME/Downloads"/*)
      die "This checkout is under a macOS privacy-protected folder ($SELF_DIR).
       Move it somewhere like ~/bazaar-skills (launchd can't read ~/Documents) and re-run ./setup." ;;
  esac
fi

# --- 2. pick the harness ---------------------------------------------------------------------
# AGENT = CLI binary (claude|codex); HARNESS = bin/harnesses name (claude-code|codex).
normalize_harness() { case "$1" in claude|claude-code) echo claude-code ;; codex) echo codex ;; *) echo "" ;; esac; }
harness_to_cli()    { [ "$1" = codex ] && echo codex || echo claude; }
signin_cmd()        { [ "$1" = codex ] && echo "codex login" || echo "claude  (then complete the login, or run /login)"; }
present_label()     { have "$1" && echo "[installed]" || echo "[not installed]"; }

if [ -n "$HOST" ]; then
  HARNESS="$(normalize_harness "$HOST")"
  [ -n "$HARNESS" ] || die "--host must be claude|claude-code|codex (got '$HOST')."
elif [ "$ASSUME_YES" = 1 ] || ! can_attach_tty; then
  # No real terminal to answer the menu (CI, piped, or inside an agent) -> don't stall on /dev/tty.
  HARNESS="$(python3 bin/bazaar-config get host 2>/dev/null || true)"
  [ -n "$HARNESS" ] || HARNESS="claude-code"   # only verified runtime → safe non-interactive default
else
  while :; do
    printf '\n'; say "Which agent runtime do you want to use?"
    printf '  1) Claude Code   %s  (supported today)\n' "$(present_label claude)"
    printf '  2) Codex         %s  (install/config only — runtime coming later)\n' "$(present_label codex)"
    printf '\033[1;36mBazaar:\033[0m Enter 1 or 2 [default 1, 10s]: '
    choice=""; read -r -t 10 choice </dev/tty || true
    case "${choice:-1}" in
      1|"") HARNESS=claude-code ;;
      2)    HARNESS=codex ;;
      q|Q)  die "Aborted. Re-run ./setup when you're ready." ;;
      *)    warn "Pick 1 or 2."; continue ;;
    esac
    break
  done
fi
AGENT="$(harness_to_cli "$HARNESS")"
if [ "$HARNESS" = codex ]; then
  warn "Codex is install/config-only today — the agent loop runs under Claude Code. Continuing config; runtime is a follow-up."
fi
if ! have "$AGENT"; then
  [ "$AGENT" = claude ] \
    && die "Claude Code CLI not found. Install it from https://claude.com/claude-code, then re-run ./setup." \
    || die "$AGENT is not installed. Install it, then re-run ./setup."
fi

# --- 3. sign-in gate -------------------------------------------------------------------------
while ! python3 bin/install.py harness --name "$HARNESS" >/dev/null 2>&1; do
  warn "$AGENT is not signed in yet."
  if can_attach_tty && [ "$ASSUME_YES" != 1 ]; then
    say "Sign in: run \`$(signin_cmd "$AGENT")\` in another terminal, then press Enter to re-check (q to quit)."
    read -r ans </dev/tty || die "No input — sign in, then re-run ./setup."
    case "$ans" in q|Q) die "Aborted. Sign in, then re-run ./setup." ;; esac
  else
    die "Sign in with \`$(signin_cmd "$AGENT")\`, then re-run ./setup."
  fi
done
say "$AGENT is signed in."

# --- 4. record home/host -------------------------------------------------------------------
python3 bin/bazaar-config set home "$SELF_DIR"        >/dev/null
python3 bin/bazaar-config set host "$HARNESS"         >/dev/null
python3 bin/bazaar-config set autonomy "$AUTONOMY"    >/dev/null
[ "$PREFIX" = 1 ] && python3 bin/bazaar-config set prefix true >/dev/null || python3 bin/bazaar-config set prefix false >/dev/null
[ -n "$TEAM" ] && python3 bin/bazaar-config set team_mode "$([ "$TEAM" = 1 ] && echo true || echo false)" >/dev/null

# --- 5. MCP config (no secrets) + autonomous-run permissions + global launchers --------------
python3 bin/install.py gen-mcp --harness "$HARNESS" --dest "$SELF_DIR" >/dev/null || warn "gen-mcp failed (continuing)."
# Ensure the harness permission allow-list for autonomous (unattended) runs is present. This is
# idempotent and MERGES — it preserves any channel token already in settings.local.json. Without
# it, an interactive /bazaar-run prompts on every tool. (The daemon's headless passes pass the same
# tools via --allowedTools; the business-approval layer is set in onboarding / the /bazaar menu.)
python3 bin/install.py gen-settings --harness "$HARNESS" --autonomy "$AUTONOMY" --dest "$SELF_DIR" >/dev/null \
  && say "Autonomous-run permissions ensured (autonomy: $AUTONOMY)." \
  || warn "gen-settings failed (continuing) — set permissions later via /bazaar → autonomy."
PREFIX_FLAG=""; [ "$PREFIX" = 1 ] && PREFIX_FLAG="--prefix"
LAUNCH_JSON="$(python3 bin/install.py gen-launchers --harness "$HARNESS" --dest "$SELF_DIR" $PREFIX_FLAG)" \
  && say "Installed global launchers → $(python3 -c 'import json,sys;d=json.load(sys.stdin);print(d["skills_dir"])' <<<"$LAUNCH_JSON")" \
  || warn "launcher install failed (continuing)."

# --- 6. migrations + version stamp -----------------------------------------------------------
VER="$(cat "$SELF_DIR/VERSION" 2>/dev/null || echo 0.0.0)"
LAST="$(cat "$HOME/.bazaar/.last-setup-version" 2>/dev/null || echo "")"
version_gt() { [ "$1" != "$2" ] && [ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | tail -1)" = "$1" ]; }
if [ -d "$SELF_DIR/migrations" ]; then
  for f in $(ls "$SELF_DIR"/migrations/v*.sh 2>/dev/null | sort -V); do
    mver="$(basename "$f" .sh)"; mver="${mver#v}"
    if [ -z "$LAST" ] || version_gt "$mver" "$LAST"; then
      say "running migration $mver"; BAZAAR_HOME="$SELF_DIR" bash "$f" || warn "migration $mver failed (continuing)."
    fi
  done
fi
mkdir -p "$HOME/.bazaar"; printf '%s\n' "$VER" > "$HOME/.bazaar/.last-setup-version"

# --- 7. first run -> onboarding; re-run -> refresh + exit -------------------------------------
if [ -f "$SELF_DIR/data/seller_config.json" ]; then
  say "Bazaar v$VER refreshed (launchers + config). Already onboarded."
  python3 bin/healthcheck.py 2>/dev/null || true   # report runnable state (read-only, no secrets)
  say "  • change settings:  /bazaar      • update later:  /bazaar-upgrade"
  exit 0
fi
export BAZAAR_HARNESS="$HARNESS"
if can_attach_tty; then
  say "First-time setup — handing off to $AGENT for guided onboarding…"
  exec "$AGENT" "$HANDOFF_PROMPT"        # bare terminal: replace this process with the onboarding session
fi
# Inside an agent / non-TTY: an exec'd nested session has no attachable TTY and would be invisible — the
# onboarding the user expects never appears. Emit an explicit directive the calling agent (or user)
# follows, then exit cleanly. The next session also self-heals (bin/hooks/onboarding_notice.py).
say "Bazaar v$VER is installed (launchers, config, migrations done) — onboarding isn't finished yet."
say "NEXT: $HANDOFF_PROMPT"
say "  • In this Claude session: run /bazaar-install  (or just say: set me up)."
say "  • In a plain terminal:     $AGENT \"$HANDOFF_PROMPT\""
exit 0
