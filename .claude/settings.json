{
  "permissions": {
    "allow": [
      "Bash(python3 tests/test_*.py:*)",
      "Bash(python3 -m pytest tests/:*)",
      "Bash(python3 -m py_compile:*)",
      "Bash(python3 bin/*.py:*)",
      "Bash(bin/*.sh:*)",
      "Bash(bash -n bin/*.sh)",
      "Bash(curl -s http://127.0.0.1:9222/*:*)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_file_upload",
      "mcp__playwright__browser_select_option",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_tabs",
      "mcp__playwright__browser_evaluate",
      "Bash(launchctl list *)",
      "Bash(launchctl kickstart *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(gh auth *)",
      "Bash(gh pr *)",
      "Bash(git fetch *)",
      "Bash(git log *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/bin/hooks/update_notice.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/bin/hooks/pause_guard.py\""
          }
        ]
      },
      {
        "matcher": "mcp__playwright__browser_click|mcp__playwright__browser_type|mcp__playwright__browser_fill_form|mcp__playwright__browser_press_key|mcp__playwright__browser_select_option|mcp__playwright__browser_file_upload|mcp__playwright__browser_navigate|mcp__playwright__browser_handle_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/bin/hooks/pause_guard.py\""
          }
        ]
      },
      {
        "matcher": "mcp__playwright__browser_navigate",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/bin/hooks/scope_guard.py\""
          }
        ]
      }
    ]
  }
}
