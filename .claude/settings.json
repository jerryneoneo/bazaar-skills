{
  "permissions": {
    "allow": [
      "Bash(python3 tests/test_*.py:*)",
      "Bash(python3 -m pytest tests/:*)",
      "Bash(python3 -m py_compile:*)",
      "Bash(python3 bin/*.py:*)",
      "Bash(bin/*.sh:*)",
      "Bash(bash -n bin/*.sh)",
      "Bash(curl -s http://127.0.0.1:9222/*:*)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_file_upload",
      "mcp__playwright__browser_select_option",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_tabs",
      "mcp__playwright__browser_evaluate",
      "Bash(launchctl list *)",
      "Bash(launchctl kickstart *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(gh auth *)",
      "Bash(gh pr *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(xargs cat)",
      "Bash(python3 tests/test_relist_state.py)",
      "Bash(python3 tests/test_inbox_scan.py)",
      "Bash(grep -iA1 \"platform offer\\\\|relist\\\\|non-relist\\\\|read assistant\\\\|already-seen offer\\\\|platform_offers key\")",
      "Bash(python3 -m pytest -q)",
      "Bash(python3 bin/inbox_scan.py platform-offers)",
      "Bash(echo \"rc=$?\")",
      "Bash(python3 bin/relist_state.py due --item smoke-test-item --market carousell)",
      "Bash(python3 -c \"import json;d=json.load\\(open\\('data/config.json'\\)\\);print\\('free_relist=',d['approvals']['steps'].get\\('free_relist'\\)\\);print\\('relist_cooldown_days=',d.get\\('relist_cooldown_days'\\)\\)\")",
      "Bash(python3 -c \"import sys; sys.path.insert\\(0,'bin'\\); import inbox_scan, relist_state; print\\('imports OK; platform_offers_now exists:', hasattr\\(inbox_scan,'platform_offers_now'\\), '| relist due fn:', hasattr\\(relist_state,'is_due'\\)\\)\")",
      "Bash(git push *)",
      "Bash(git rev-list *)",
      "Bash(grep -E \"origin/main$\")",
      "Bash(python3 tests/test_agent_daemon.py)",
      "Bash(python3 tests/test_thread_outbox.py)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/bin/hooks/update_notice.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/bin/hooks/onboarding_notice.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/bin/hooks/pause_guard.py\""
          }
        ]
      },
      {
        "matcher": "mcp__playwright__browser_click|mcp__playwright__browser_type|mcp__playwright__browser_fill_form|mcp__playwright__browser_press_key|mcp__playwright__browser_select_option|mcp__playwright__browser_file_upload|mcp__playwright__browser_navigate|mcp__playwright__browser_handle_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/bin/hooks/pause_guard.py\""
          }
        ]
      },
      {
        "matcher": "mcp__playwright__browser_navigate",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/bin/hooks/scope_guard.py\""
          }
        ]
      }
    ]
  }
}
