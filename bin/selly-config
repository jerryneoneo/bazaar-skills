#!/usr/bin/env python3
"""selly-config — tiny key-value store for SELLY's cross-cutting install state.

Mirrors gstack's `gstack-config`. Persists to ~/.selly/config.json (JSON object). Used by `setup`,
the global launchers, `/selly-upgrade`, and `bin/selly-uninstall`.

  selly-config get <key>            -> prints the value (empty + exit 1 if unset)
  selly-config set <key> <value>    -> writes the key
  selly-config list                 -> prints the whole config as JSON

Known keys: home (runtime dir), host (selected harness), prefix (true/false), autonomy,
auto_upgrade (true/false), team_mode (true/false). The `home` value is ALSO mirrored to the plain
text file ~/.selly/home, which the launchers read with a simple `cat`.

Exit: 0 ok · 1 key not found · 2 bad input.
"""

from __future__ import annotations

import json
import sys
from pathlib import Path

CONFIG_DIR = Path.home() / ".selly"
CONFIG_PATH = CONFIG_DIR / "config.json"
HOME_POINTER = CONFIG_DIR / "home"


def _load() -> dict:
    if not CONFIG_PATH.exists():
        return {}
    try:
        data = json.loads(CONFIG_PATH.read_text())
        return data if isinstance(data, dict) else {}
    except (OSError, ValueError):
        return {}


def _save(data: dict) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_PATH.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")


def cmd_get(key: str) -> int:
    data = _load()
    if key not in data:
        return 1
    print(data[key])
    return 0


def cmd_set(key: str, value: str) -> int:
    data = {**_load(), key: value}  # new dict; never mutate the loaded one in place
    _save(data)
    if key == "home":  # mirror to the plain-text pointer the launchers cat
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        HOME_POINTER.write_text(value + "\n")
    return 0


def cmd_list() -> int:
    print(json.dumps(_load(), indent=2, sort_keys=True))
    return 0


def main(argv: list[str]) -> int:
    if len(argv) < 2:
        sys.stderr.write("usage: selly-config <get|set|list> [key] [value]\n")
        return 2
    cmd = argv[1]
    if cmd == "get" and len(argv) == 3:
        return cmd_get(argv[2])
    if cmd == "set" and len(argv) == 4:
        return cmd_set(argv[2], argv[3])
    if cmd == "list" and len(argv) == 2:
        return cmd_list()
    sys.stderr.write("usage: selly-config <get|set|list> [key] [value]\n")
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv))
